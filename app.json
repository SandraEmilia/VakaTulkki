{
  "expo": {
    "name": "VakaTulkki",
    "slug": "VakaTulkki",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vakatulkki",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EAF6FF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sandraemilia.vakatulkki"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "resizeMode": "cover",
          "backgroundColor": "#EAF6FF",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "761889e1-5306-40fb-8841-457695a25eb4"
      }
    }
  }
}
